# ── CampusDrive — Environment Variables Template ──────────────────
# Copy this file to .env and fill in your actual credentials.
#   cp .env.example .env
#
# For Vercel deployment: add these same variables in
# Vercel Dashboard → Project → Settings → Environment Variables.
# Set scope to Production + Preview + Development.

# Flask Session Signing Key (generate via: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change_me_to_a_random_secret_key

# MongoDB Atlas Connection String
# Create a free cluster at https://cloud.mongodb.com
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/campusdrive?retryWrites=true&w=majority

# Google Gemini API Key (for Aradhaya AI Assistant)
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# Flask Debug Mode (only enable in development)
# DEBUG=True
